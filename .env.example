# ==============================================================================
# BACKEND CONFIGURATION (.env in the root folder)
# ==============================================================================

# --- MICROSOFT ENTRA ID (Backend Pipeline) ---
# Used for Graph API access (OneDrive scans, Email sending)
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# --- DATABASE ---
# Format: postgresql+asyncpg://user:pass@host:port/db
DATABASE_URL=postgresql+asyncpg://meeting:meeting@localhost:5434/meeting_intel

# --- AI SERVICES ---
# Implementation: assemblyai | mock
TRANSCRIBER_IMPL=assemblyai
ASSEMBLYAI_API_KEY=

# Implementation: anthropic | azure_openai | mock
EXTRACTOR_IMPL=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- INFRASTRUCTURE ---
# Service Bus Connection (Azure only)
SERVICEBUS_CONNECTION_STRING=
SERVICEBUS_QUEUE_NAME=meeting-jobs

# Master switch for emails
EMAILS_ENABLED=true
MAIL_SENDER_UPN=noreply@taxconsulting.co.za
AUTO_SEND_EMAIL=false
POPIA_NOTICE_ENABLED=true

# --- SECURITY & WEBHOOKS ---
ALLOWED_DOMAIN=taxconsulting.co.za
WEBHOOK_BASE_URL=https://your-ngrok-id.ngrok.app
WEBHOOK_CLIENT_STATE=
RECONCILE_SECRET=
SUBSCRIPTION_SECRET=

# ==============================================================================
# FRONTEND CONFIGURATION (Also uses the root .env or frontend/.env.local)
# ==============================================================================

# NextAuth Secret (Generate with: npx auth secret)
AUTH_SECRET=

# Microsoft Entra ID (Frontend Login)
AUTH_MICROSOFT_ENTRA_ID_ID=your-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-client-secret
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=your-tenant-id

# Public API URL for the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
